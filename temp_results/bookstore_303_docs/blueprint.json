{
  "metadata": {
    "application_name": "Bookstore",
    "architecture_pattern": "Basic Serverless Architecture",
    "has_authentication": true,
    "has_database": true,
    "has_file_storage": false
  },
  "lambda_functions": [
    {
      "name": "books-get-all",
      "runtime": "nodejs18.x",
      "handler": "handler.getAllBooks",
      "source_files": ["bookstore/routes/books.js"],
      "entry_points": ["GET /books"],
      "environment_variables": {
        "BOOKS_TABLE": "${BooksTable}"
      }
    },
    {
      "name": "books-get-by-id",
      "runtime": "nodejs18.x",
      "handler": "handler.getBookById",
      "source_files": ["bookstore/routes/books.js"],
      "entry_points": ["GET /books/{id}"],
      "environment_variables": {
        "BOOKS_TABLE": "${BooksTable}"
      }
    },
    {
      "name": "cart-get-all",
      "runtime": "nodejs18.x",
      "handler": "handler.getCart",
      "source_files": ["bookstore/routes/cart.js"],
      "entry_points": ["GET /cart"],
      "environment_variables": {
        "CART_TABLE": "${CartTable}"
      }
    },
    {
      "name": "cart-get-item",
      "runtime": "nodejs18.x",
      "handler": "handler.getCartItem",
      "source_files": ["bookstore/routes/cart.js"],
      "entry_points": ["GET /cart/{bookId}"],
      "environment_variables": {
        "CART_TABLE": "${CartTable}"
      }
    },
    {
      "name": "cart-add-item",
      "runtime": "nodejs18.x",
      "handler": "handler.addToCart",
      "source_files": ["bookstore/routes/cart.js"],
      "entry_points": ["POST /cart"],
      "environment_variables": {
        "CART_TABLE": "${CartTable}"
      }
    },
    {
      "name": "cart-update-item",
      "runtime": "nodejs18.x",
      "handler": "handler.updateCart",
      "source_files": ["bookstore/routes/cart.js"],
      "entry_points": ["PUT /cart"],
      "environment_variables": {
        "CART_TABLE": "${CartTable}"
      }
    },
    {
      "name": "cart-delete-item",
      "runtime": "nodejs18.x",
      "handler": "handler.deleteFromCart",
      "source_files": ["bookstore/routes/cart.js"],
      "entry_points": ["DELETE /cart"],
      "environment_variables": {
        "CART_TABLE": "${CartTable}"
      }
    },
    {
      "name": "orders-get-all",
      "runtime": "nodejs18.x",
      "handler": "handler.getOrders",
      "source_files": ["bookstore/routes/orders.js"],
      "entry_points": ["GET /orders"],
      "environment_variables": {
        "ORDERS_TABLE": "${OrdersTable}"
      }
    },
    {
      "name": "orders-create",
      "runtime": "nodejs18.x",
      "handler": "handler.createOrder",
      "source_files": ["bookstore/routes/orders.js"],
      "entry_points": ["POST /orders"],
      "environment_variables": {
        "ORDERS_TABLE": "${OrdersTable}",
        "BOOKS_TABLE": "${BooksTable}",
        "CART_TABLE": "${CartTable}"
      }
    },
    {
      "name": "bestsellers-get",
      "runtime": "nodejs18.x",
      "handler": "handler.getBestsellers",
      "source_files": ["bookstore/routes/bestsellers.js"],
      "entry_points": ["GET /bestsellers"],
      "environment_variables": {
        "REDIS_ENDPOINT": "${RedisEndpoint}"
      }
    },
    {
      "name": "recommendations-get-all",
      "runtime": "nodejs18.x",
      "handler": "handler.getRecommendations",
      "source_files": ["bookstore/routes/recommendations.js"],
      "entry_points": ["GET /recommendations"],
      "environment_variables": {
        "NEPTUNE_ENDPOINT": "${NeptuneEndpoint}"
      }
    },
    {
      "name": "recommendations-get-by-book",
      "runtime": "nodejs18.x",
      "handler": "handler.getBookRecommendations",
      "source_files": ["bookstore/routes/recommendations.js"],
      "entry_points": ["GET /recommendations/{bookId}"],
      "environment_variables": {
        "NEPTUNE_ENDPOINT": "${NeptuneEndpoint}"
      }
    },
    {
      "name": "search-books",
      "runtime": "nodejs18.x",
      "handler": "handler.searchBooks",
      "source_files": ["bookstore/routes/search.js"],
      "entry_points": ["GET /search"],
      "environment_variables": {
        "ELASTICSEARCH_ENDPOINT": "${ElasticsearchEndpoint}",
        "BOOKS_TABLE": "${BooksTable}"
      }
    }
  ],
  "dynamodb_tables": [
    {
      "logical_name": "Books",
      "purpose": "Store book information and inventory",
      "partition_key": {
        "name": "id",
        "type": "S"
      },
      "gsi": [
        {
          "index_name": "category-index",
          "partition_key": {
            "name": "category",
            "type": "S"
          }
        }
      ]
    },
    {
      "logical_name": "Cart",
      "purpose": "Store user shopping cart items",
      "partition_key": {
        "name": "customerId",
        "type": "S"
      },
      "sort_key": {
        "name": "bookId",
        "type": "S"
      }
    },
    {
      "logical_name": "Orders",
      "purpose": "Store user orders and order history",
      "partition_key": {
        "name": "customerId",
        "type": "S"
      },
      "sort_key": {
        "name": "orderId",
        "type": "S"
      }
    }
  ],
  "s3_buckets": [],
  "cognito": {
    "enabled": true,
    "user_pool_attributes": ["email", "name"],
    "password_policy": {
      "min_length": 8,
      "require_symbols": true,
      "require_numbers": true,
      "require_lowercase": true,
      "require_uppercase": true
    }
  },
  "api_gateway": {
    "type": "REST",
    "cors": {
      "allow_origins": ["*"],
      "allow_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "allow_headers": ["Content-Type", "Authorization", "X-Amz-Date", "X-Api-Key", "X-Amz-Security-Token"],
      "max_age": 86400
    },
    "authorizer": "Cognito"
  },
  "lambda_invoke_permissions": [],
  "dropped_functions": [
    {
      "item": "POST /register",
      "type": "endpoint",
      "reason": "Replaced by Cognito User Pool registration - frontend calls AWS Amplify/Cognito SDK directly"
    },
    {
      "item": "POST /login",
      "type": "endpoint",
      "reason": "Replaced by Cognito User Pool authentication - frontend calls AWS Amplify/Cognito SDK directly"
    },
    {
      "item": "POST /refresh",
      "type": "endpoint",
      "reason": "Replaced by Cognito User Pool token refresh - frontend calls AWS Amplify/Cognito SDK directly"
    },
    {
      "item": "GET /me",
      "type": "endpoint",
      "reason": "Replaced by Cognito - client reads user info directly from JWT token claims"
    },
    {
      "item": "authMiddleware",
      "type": "code",
      "reason": "Replaced by API Gateway Cognito Authorizer - token validation at gateway layer"
    },
    {
      "item": "optionalAuthMiddleware",
      "type": "code",
      "reason": "Replaced by API Gateway Cognito Authorizer - token validation at gateway layer"
    },
    {
      "item": "verifyToken middleware / auth decorators",
      "type": "code",
      "reason": "Replaced by API Gateway Cognito Authorizer - token validation at gateway layer"
    },
    {
      "item": "init-db.js",
      "type": "script",
      "reason": "Infrastructure script - table creation handled by SAM template CloudFormation resources"
    },
    {
      "item": "Users table",
      "type": "table",
      "reason": "User authentication moved to Cognito User Pool - entire users table deleted"
    },
    {
      "item": "JWT token generation/validation utilities",
      "type": "code",
      "reason": "Replaced by Cognito User Pool token management - JWT handled by AWS managed service"
    },
    {
      "item": "Password hashing/verification utilities",
      "type": "code",
      "reason": "Replaced by Cognito User Pool password management - handled by AWS managed service"
    }
  ]
}