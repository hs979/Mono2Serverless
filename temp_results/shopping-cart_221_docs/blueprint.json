{
  "metadata": {
    "application_name": "shopping-cart",
    "architecture_pattern": "Basic Serverless Architecture",
    "has_authentication": true,
    "has_database": true,
    "has_file_storage": true
  },
  "common_dependencies": {
    "python": ["boto3", "datetime", "json", "uuid", "decimal"]
  },
  "lambda_layers": [
    {
      "name": "base-python-utils",
      "runtime_family": "python",
      "compatible_runtimes": ["python3.11", "python3.12"],
      "dependencies": ["boto3"],
      "purpose": "Common AWS SDK and utilities used by all Lambda functions"
    }
  ],
  "lambda_functions": [
    {
      "name": "products-get-all",
      "runtime": "python3.11",
      "handler": "handler.lambda_handler",
      "source_files": ["shopping-cart/app.py", "shopping-cart/models.py", "shopping-cart/db.py"],
      "entry_points": ["GET /product"],
      "layers": ["base-python-utils"],
      "environment_variables": {
        "DYNAMODB_TABLE_NAME": "${ShoppingCartTable}"
      }
    },
    {
      "name": "products-get-by-id",
      "runtime": "python3.11",
      "handler": "handler.lambda_handler",
      "source_files": ["shopping-cart/app.py", "shopping-cart/models.py", "shopping-cart/db.py"],
      "entry_points": ["GET /product/{product_id}"],
      "layers": ["base-python-utils"],
      "environment_variables": {
        "DYNAMODB_TABLE_NAME": "${ShoppingCartTable}"
      }
    },
    {
      "name": "cart-get-items",
      "runtime": "python3.11",
      "handler": "handler.lambda_handler",
      "source_files": ["shopping-cart/app.py", "shopping-cart/models.py", "shopping-cart/db.py"],
      "entry_points": ["GET /cart"],
      "layers": ["base-python-utils"],
      "environment_variables": {
        "DYNAMODB_TABLE_NAME": "${ShoppingCartTable}"
      }
    },
    {
      "name": "cart-add-item",
      "runtime": "python3.11",
      "handler": "handler.lambda_handler",
      "source_files": ["shopping-cart/app.py", "shopping-cart/models.py", "shopping-cart/db.py"],
      "entry_points": ["POST /cart"],
      "layers": ["base-python-utils"],
      "environment_variables": {
        "DYNAMODB_TABLE_NAME": "${ShoppingCartTable}"
      }
    },
    {
      "name": "cart-update-item",
      "runtime": "python3.11",
      "handler": "handler.lambda_handler",
      "source_files": ["shopping-cart/app.py", "shopping-cart/models.py", "shopping-cart/db.py"],
      "entry_points": ["PUT /cart/{product_id}"],
      "layers": ["base-python-utils"],
      "environment_variables": {
        "DYNAMODB_TABLE_NAME": "${ShoppingCartTable}"
      }
    },
    {
      "name": "cart-migrate",
      "runtime": "python3.11",
      "handler": "handler.lambda_handler",
      "source_files": ["shopping-cart/app.py", "shopping-cart/models.py", "shopping-cart/db.py"],
      "entry_points": ["POST /cart/migrate"],
      "layers": ["base-python-utils"],
      "environment_variables": {
        "DYNAMODB_TABLE_NAME": "${ShoppingCartTable}"
      }
    },
    {
      "name": "cart-checkout",
      "runtime": "python3.11",
      "handler": "handler.lambda_handler",
      "source_files": ["shopping-cart/app.py", "shopping-cart/models.py", "shopping-cart/db.py"],
      "entry_points": ["POST /cart/checkout"],
      "layers": ["base-python-utils"],
      "environment_variables": {
        "DYNAMODB_TABLE_NAME": "${ShoppingCartTable}"
      }
    },
    {
      "name": "cart-get-total",
      "runtime": "python3.11",
      "handler": "handler.lambda_handler",
      "source_files": ["shopping-cart/app.py", "shopping-cart/models.py", "shopping-cart/db.py"],
      "entry_points": ["GET /cart/{product_id}/total"],
      "layers": ["base-python-utils"],
      "environment_variables": {
        "DYNAMODB_TABLE_NAME": "${ShoppingCartTable}"
      }
    },
    {
      "name": "cognito-post-confirmation",
      "runtime": "python3.11",
      "handler": "handler.lambda_handler",
      "source_files": ["shopping-cart/models.py", "shopping-cart/db.py"],
      "entry_points": [],
      "layers": ["base-python-utils"],
      "environment_variables": {
        "DYNAMODB_TABLE_NAME": "${ShoppingCartTable}"
      },
      "is_trigger": true,
      "trigger_source": "Cognito Post-Confirmation"
    }
  ],
  "dynamodb_tables": [
    {
      "logical_name": "ShoppingCartTable",
      "purpose": "Single-table design for shopping cart application storing users, products, and cart items",
      "schema_source_files": ["shopping-cart/init_dynamodb.py", "shopping-cart/models.py", "shopping-cart/db.py"]
    }
  ],
  "s3_buckets": [
    {
      "logical_name": "FileStorageBucket",
      "purpose": "Store user-uploaded files and product images"
    }
  ],
  "cognito": {
    "enabled": true,
    "user_pool_attributes": ["email", "name"],
    "password_policy": {
      "min_length": 8,
      "require_symbols": true,
      "require_numbers": true,
      "require_uppercase": true,
      "require_lowercase": true
    },
    "triggers": {
      "post_confirmation": {
        "enabled": true,
        "purpose": "Create user profile record in DynamoDB after successful registration",
        "lambda_function": "cognito-post-confirmation"
      }
    }
  },
  "api_gateway": {
    "type": "REST",
    "cors": {
      "allow_origins": ["*"],
      "allow_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "allow_headers": ["Content-Type", "Authorization", "X-Amz-Date", "X-Api-Key", "X-Amz-Security-Token"],
      "max_age": 86400
    },
    "authorizer": "Cognito"
  },
  "table_initialization": [
    {
      "table": "ShoppingCartTable",
      "source_file": "shopping-cart/init_dynamodb.py",
      "strategy": "Custom Resource Lambda during CloudFormation deployment"
    }
  ],
  "dropped_functions": [
    {
      "item": "POST /auth/register",
      "type": "endpoint",
      "reason": "Replaced by Cognito User Pool - Frontend calls AWS Amplify Auth.signUp()",
      "frontend_integration": "import { Auth } from 'aws-amplify'; await Auth.signUp({username: email, password, attributes: {email, name}})"
    },
    {
      "item": "POST /auth/login",
      "type": "endpoint",
      "reason": "Replaced by Cognito User Pool - Frontend calls AWS Amplify Auth.signIn()",
      "frontend_integration": "import { Auth } from 'aws-amplify'; await Auth.signIn(username, password)"
    },
    {
      "item": "login_required middleware / verifyToken decorator",
      "type": "code",
      "reason": "Replaced by API Gateway Cognito Authorizer - Token validation at gateway layer, not in Lambda code",
      "frontend_integration": "API Gateway automatically validates JWT tokens; include 'Authorization: Bearer <token>' header in requests"
    },
    {
      "item": "init_dynamodb.py",
      "type": "script",
      "reason": "Infrastructure script - Table creation handled by SAM template CloudFormation resources"
    },
    {
      "item": "Users table credentials (password_hash field)",
      "type": "table_field",
      "reason": "User authentication moved to Cognito User Pool - Password storage handled by Cognito, not DynamoDB"
    },
    {
      "item": "auth.py (JWT token creation/validation)",
      "type": "module",
      "reason": "Token management replaced by Cognito User Pool - Cognito issues and validates JWT tokens"
    }
  ]
}