{
  "metadata": {
    "application_name": "TodoApp",
    "architecture_pattern": "Basic Serverless Architecture",
    "has_authentication": true,
    "has_database": true,
    "has_file_storage": false
  },
  "lambda_functions": [
    {
      "name": "todo-get-items",
      "runtime": "python3.11",
      "handler": "handler.lambda_handler",
      "source_files": ["todo/routes/todo.js", "todo/config/db.js"],
      "entry_points": ["GET /item"],
      "environment_variables": {
        "TODO_TABLE": "${TodoTable}"
      }
    },
    {
      "name": "todo-get-item-by-id",
      "runtime": "python3.11",
      "handler": "handler.lambda_handler",
      "source_files": ["todo/routes/todo.js", "todo/config/db.js"],
      "entry_points": ["GET /item/{id}"],
      "environment_variables": {
        "TODO_TABLE": "${TodoTable}"
      }
    },
    {
      "name": "todo-create-item",
      "runtime": "python3.11",
      "handler": "handler.lambda_handler",
      "source_files": ["todo/routes/todo.js", "todo/config/db.js"],
      "entry_points": ["POST /item"],
      "environment_variables": {
        "TODO_TABLE": "${TodoTable}"
      }
    },
    {
      "name": "todo-update-item",
      "runtime": "python3.11",
      "handler": "handler.lambda_handler",
      "source_files": ["todo/routes/todo.js", "todo/config/db.js"],
      "entry_points": ["PUT /item/{id}"],
      "environment_variables": {
        "TODO_TABLE": "${TodoTable}"
      }
    },
    {
      "name": "todo-mark-item-done",
      "runtime": "python3.11",
      "handler": "handler.lambda_handler",
      "source_files": ["todo/routes/todo.js", "todo/config/db.js"],
      "entry_points": ["POST /item/{id}/done"],
      "environment_variables": {
        "TODO_TABLE": "${TodoTable}"
      }
    },
    {
      "name": "todo-delete-item",
      "runtime": "python3.11",
      "handler": "handler.lambda_handler",
      "source_files": ["todo/routes/todo.js", "todo/config/db.js"],
      "entry_points": ["DELETE /item/{id}"],
      "environment_variables": {
        "TODO_TABLE": "${TodoTable}"
      }
    }
  ],
  "lambda_invoke_permissions": [],
  "dynamodb_tables": [
    {
      "logical_name": "TodoTable",
      "purpose": "Store todo items",
      "partition_key": {
        "name": "cognito-username",
        "type": "S"
      },
      "sort_key": {
        "name": "id",
        "type": "S"
      },
      "gsi": []
    }
  ],
  "s3_buckets": [],
  "cognito": {
    "enabled": true,
    "user_pool_attributes": ["email", "name"],
    "password_policy": {
      "min_length": 8,
      "require_symbols": true,
      "require_numbers": true,
      "require_uppercase": true,
      "require_lowercase": true
    }
  },
  "api_gateway": {
    "type": "REST",
    "cors": {
      "allow_origins": ["*"],
      "allow_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "allow_headers": ["Content-Type", "Authorization"],
      "max_age": 86400
    },
    "authorizer": "Cognito"
  },
  "dropped_functions": [
    {
      "item": "POST /register",
      "type": "endpoint",
      "reason": "Replaced by Cognito User Pool registration"
    },
    {
      "item": "POST /login",
      "type": "endpoint",
      "reason": "Replaced by Cognito User Pool authentication"
    },
    {
      "item": "verifyToken middleware / auth decorators",
      "type": "code",
      "reason": "Replaced by API Gateway Cognito Authorizer - token validation at gateway layer"
    },
    {
      "item": "JWT generation and verification utilities",
      "type": "code",
      "reason": "Replaced by Cognito JWT tokens - token generation and validation handled by Cognito"
    },
    {
      "item": "init-db.js",
      "type": "script",
      "reason": "Infrastructure script - table creation handled by SAM template CloudFormation resources"
    },
    {
      "item": "USER_TABLE (Users table)",
      "type": "table",
      "reason": "User authentication moved to Cognito User Pool - entire users table deleted"
    }
  ]
}